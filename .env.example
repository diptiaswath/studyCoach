# Together.ai API Configuration
# Get your API key at: https://api.together.ai
# Copy this file to .env and fill in your key:
#   cp .env.example .env
#
# Then source it before running:
#   source .env

export TOGETHER_API_KEY="your-together-api-key-here"

# Anthropic API (for LLM-as-Judge feedback evaluation)
