\@writefile{toc}{\contentsline {subsection}{\numberline {1.3}Qualitative Analysis and Examples}{8}{subsection.1.3}\protected@file@percent }
\newlabel{sec:qual}{{1.3}{8}{Qualitative Analysis and Examples}{subsection.1.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces \texttt  {\textbf  {\textcolor {blue}{[2 points]}}} Qualitative failure analysis (Qwen3-VL-8B, text-only condition, H3 evaluation set). Two failure modes: \textbf  {Verdict Inflation} (examples 2, 3, 5)---model predicts Correct with N/A feedback, silencing the coaching pipeline; \textbf  {Hallucinated Correction} (examples 1, 4)---model predicts Incorrect with confident but wrong feedback. Root cause: without the figure, the model performs plausibility checking rather than evidence-based verification. Visual context (C4) reduces both modes by grounding reasoning in figure content, explaining why feedback quality improves even as PC Recall drops.}}{8}{table.5}\protected@file@percent }
\newlabel{tab:qual}{{5}{8}{\points {2} Qualitative failure analysis (Qwen3-VL-8B, text-only condition, H3 evaluation set). Two failure modes: \textbf {Verdict Inflation} (examples 2, 3, 5)---model predicts Correct with N/A feedback, silencing the coaching pipeline; \textbf {Hallucinated Correction} (examples 1, 4)---model predicts Incorrect with confident but wrong feedback. Root cause: without the figure, the model performs plausibility checking rather than evidence-based verification. Visual context (C4) reduces both modes by grounding reasoning in figure content, explaining why feedback quality improves even as PC Recall drops}{table.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Qualitative comparison of C4 baseline vs.\ C4-CoT (Modification~4), Qwen3-VL-32B. $\text  {$\mathsurround \z@ \mathchar "458$}$ marks the correct verdict. PC = Partially Correct. Examples 1--3: CoT prevents verdict inflation by grounding in figure evidence. Examples 4--6: CoT over-corrects or over-confirms, misclassifying the severity of the error.}}{9}{table.6}\protected@file@percent }
\newlabel{tab:cot_qual}{{6}{9}{Qualitative comparison of C4 baseline vs.\ C4-CoT (Modification~4), Qwen3-VL-32B. $\checkmark $ marks the correct verdict. PC = Partially Correct. Examples 1--3: CoT prevents verdict inflation by grounding in figure evidence. Examples 4--6: CoT over-corrects or over-confirms, misclassifying the severity of the error}{table.6}{}}
